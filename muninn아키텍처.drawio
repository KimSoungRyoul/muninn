        <mxCell id="Zi7zoUne9gZOS5BG8vyO-58" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Muninn 이 하는 역할은 기억을 관리하고&amp;nbsp;&lt;div&gt;Huggin Agent 실행시&amp;nbsp; metaDB에 저장된 application 별 memories와 platform tools memories를 검색해서&amp;nbsp;&lt;/div&gt;&lt;div&gt;Huggin Session 생성시 도움될만한&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;muninn memoires 프롬프트를 전달 해주는것&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;그리고&amp;nbsp;&lt;/div&gt;&lt;div&gt;Huggin 이 동작을 완료하면 이 history 들을 받아서 요약해서 metaDB에 저장해서 다음번 Session 실행시 검색가능하게 저장해놓기&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="153" width="340" x="222" y="17" as="geometry" />
        </mxCell>
